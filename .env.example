# Copy to your local .env (do not commit secrets)

# PostgreSQL (required for persistence)
DB_URL=jdbc:postgresql://localhost:5432/studio_ai
DB_USERNAME=studio_ai
DB_PASSWORD=studio_ai

# DashScope (required for AI features)
DASHSCOPE_API_KEY=

# Pinecone (optional)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=studio-ai-center
PINECONE_DIMENSION=1024

# Redis (optional, recommended)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (required for auth)
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=100

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=jasmine5606
GITHUB_DEFAULT_REPO=jasmine

# MCP (optional)
MCP_ENABLED=false

# Bilibili (optional)
BILIBILI_API_BASE_URL=https://api.bilibili.com

# App auth (recommended for multi-user)
# Configure users in application-secrets.yml (gitignored), e.g.
# auth:
#   users:
#     - username: admin
#       password: change_me
#       role: ADMIN
